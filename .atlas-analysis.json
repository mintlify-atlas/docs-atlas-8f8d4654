  "keyFeatures": [
    "User authentication with role-based access (student/professor)",
    "Interactive forum activities for learning derivatives",
    "Multiple exam types with automatic submission tracking",
    "Professor dashboard for student progress monitoring",
    "Feedback system for personalized learning",
    "Image upload support for mathematical sketches"
  ],
  "publicApiSurface": [
    "POST /registrar - User registration",
    "POST /login - User authentication",
    "POST /guardar_foro{foro_id} - Submit forum responses",
    "GET /respuestas_foro{foro_id} - Get forum responses",
    "POST /guardar_examen1 - Submit exam 1",
    "POST /guardar_examen2 - Submit exam 2",
    "GET /lista_estudiantes - Get student list (professor)",
    "GET /expediente_completo/{email} - Get student record",
    "POST /guardar_feedback - Submit feedback",
    "GET /obtener_feedback/{email} - Get student feedback"
  ]
}
